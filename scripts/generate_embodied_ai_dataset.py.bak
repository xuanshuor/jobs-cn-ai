def main() -> None:
    jobs: list[dict] = []
    for row in ROWS:
        jid = row[0]
        if jid in ALT:
            for sub in ALT[jid]:
                jobs.append(build_job(*sub))
            continue
        jobs.append(build_job(*row))

    n = len(jobs)
    dataset = {
        "schemaVersion": 1,
        "meta": {
            "title": "中国就业市场：具身智能与 AI 替代压力分析",
            "subtitle": f"约 {n} 个代表性职业 · 面积 = 就业人数（万人）· 颜色 = 综合替代压力（0–10）",
            "employmentUnit": "10k",
            "generatedAt": date.today().isoformat(),
            "sourceNote": "模型化估算：含同业内低/高端岗位拆分；综合人形/移动机器人、机械臂与生成式 AI；非官方统计，仅供研究与可视化。",
        },
        "jobs": jobs,
    }

    out = json.dumps(dataset, ensure_ascii=False, indent=2) + "\n"
    OUT_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(OUT_PATH, "w", encoding="utf-8") as f:
        f.write(out)
    print("Wrote", OUT_PATH, "jobs=", n)


if __name__ == "__main__":
    main()
