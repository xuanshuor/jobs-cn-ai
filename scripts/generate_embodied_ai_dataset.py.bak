"""一次性脚本：生成具身智能 + 生成式 AI 视角下的综合替代压力数据集。"""
from __future__ import annotations

import json
from datetime import date
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
OUT_PATH = ROOT / "public" / "data" / "jobs.sample.json"

WE_EMB, WE_COG = 0.42, 0.58  # 具身权重略升：人形/移动机器人渗透加速


def blend(e: float, c: float) -> float:
    return round(min(10.0, WE_EMB * e + WE_COG * c), 1)


def build_job(
    jid: str,
    title: str,
    emp: int,
    sal: int,
    edu: str,
    sector: str,
    ind: str,
    e: float,
    c: float,
    tier: str | None = None,
) -> dict:
    d: dict = {
        "id": jid,
        "title": title,
        "employment": emp,
        "salaryMedianAnnual": sal,
        "education": edu,
        "sector": sector,
        "industryLabel": ind,
        "embodiedSubstitution": e,
        "cognitiveAiSubstitution": c,
        "aiImpact": blend(e, c),
    }
    if tier:
        d["positionTier"] = tier
    return d


